# Mô phỏng CK/MoMo/ZaloPay (tự xác nhận TT, không hiện QR thật trên frontend nếu bật cả NEXT_PUBLIC_*). Mặc định: tắt. Bật: 1 hoặc true
DEMO_SIMULATE_PREPAID_PAYMENT=0
# Khi có secret: tự động xác nhận thanh toán + chuyển đơn pending→confirmed nếu số tiền webhook khớp tổng đơn. Đặt 0 để tắt (chỉ ghi nhận giao dịch, admin bấm tay).
BANK_WEBHOOK_AUTO_CONFIRM=1
# Sepay / webhook sao kê — bảo vệ URL. Để trống khi chưa dùng.
BANK_WEBHOOK_SECRET=

# ===== Email xác nhận đơn hàng (SMTP) =====
# Để trống 3 dòng MAIL_HOST/MAIL_USER/MAIL_PASS thì hệ thống tự bỏ qua gửi email (không lỗi).
# Gmail: bật xác minh 2 bước rồi tạo "App password" (https://myaccount.google.com/apppasswords),
#        dùng app password đó cho MAIL_PASS (KHÔNG dùng mật khẩu Gmail thường).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_16_chars
# Tên/email người gửi hiển thị (mặc định = MAIL_USER nếu để trống)
MAIL_FROM=your_email@gmail.com

# ===== VNPay Sandbox (tiền ảo — dùng demo đồ án: ký HMAC-SHA512 + IPN) =====
# Đăng ký miễn phí tài khoản merchant sandbox tại https://sandbox.vnpayment.vn/devtool/ (không cần GPKD).
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:5000/api/orders/vnpay/return
