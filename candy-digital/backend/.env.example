PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=candy_digital
JWT_SECRET=candy_digital_jwt_secret_2024_very_long_key
JWT_EXPIRES_IN=7d
# Lấy key tại https://aistudio.google.com/app/apikey — KHÔNG commit key thật vào file này!
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
CLIENT_URL=http://localhost:3000
# Mô phỏng CK/MoMo/ZaloPay (tự xác nhận TT, không hiện QR thật trên frontend nếu bật cả NEXT_PUBLIC_*). Mặc định: tắt. Bật: 1 hoặc true
DEMO_SIMULATE_PREPAID_PAYMENT=0
# Khi có secret: tự động xác nhận thanh toán + chuyển đơn pending→confirmed nếu số tiền webhook khớp tổng đơn. Đặt 0 để tắt (chỉ ghi nhận giao dịch, admin bấm tay).
BANK_WEBHOOK_AUTO_CONFIRM=1
# Sepay / webhook sao kê — bảo vệ URL. Để trống khi chưa dùng.
BANK_WEBHOOK_SECRET=

# ===== Email xác nhận đơn hàng (SMTP) =====
# Để trống 3 dòng MAIL_HOST/MAIL_USER/MAIL_PASS thì hệ thống tự bỏ qua gửi email (không lỗi).
# Gmail: bật xác minh 2 bước rồi tạo "App password" (https://myaccount.google.com/apppasswords),
#        dùng app password đó cho MAIL_PASS (KHÔNG dùng mật khẩu Gmail thường).
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_16_chars
# Tên/email người gửi hiển thị (mặc định = MAIL_USER nếu để trống)
MAIL_FROM=your_email@gmail.com

# ===== VNPay (demo đồ án: ký HMAC-SHA512 + IPN) =====
# CÁCH 1 — Cổng GIẢ LẬP (khuyên dùng cho demo, KHÔNG cần tài khoản VNPay):
#   Đặt VNP_MOCK=1 + 2 giá trị bất kỳ cho TMN_CODE/HASH_SECRET là chạy được ngay.
#   payUrl/returnUrl tự suy ra từ host (localhost khi dev, RENDER_EXTERNAL_URL khi deploy Render).
# CÁCH 2 — VNPay Sandbox THẬT: đặt VNP_MOCK=0, đăng ký miễn phí tại
#   https://sandbox.vnpayment.vn/devtool/ rồi điền TMN_CODE/HASH_SECRET thật + VNP_URL sandbox.
VNP_MOCK=1
VNP_TMN_CODE=CANDYDEMO
VNP_HASH_SECRET=candy_digital_vnpay_demo_secret_2024
# Để trống VNP_URL khi dùng cổng giả lập (tự suy ra). Chỉ điền khi dùng sandbox thật:
# VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Để trống VNP_RETURN_URL → tự suy ra "<host>/api/orders/vnpay/return".
VNP_RETURN_URL=
