{
  "name": "candy-digital-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:customer dev:admin",
    "dev:customer": "cross-env NEXT_PUBLIC_APP_MODE=customer next dev -p 3000",
    "dev:admin": "cross-env NEXT_PUBLIC_APP_MODE=admin next dev -p 3001",
    "dev:clean": "npm run clean && npm run dev",
    "clean": "node -e \"const fs=require('fs');['.next','.next-customer','.next-admin','node_modules/.cache'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "build": "cross-env NEXT_PUBLIC_APP_MODE=customer next build",
    "build:admin": "cross-env NEXT_PUBLIC_APP_MODE=admin next build",
    "start:customer": "cross-env NEXT_PUBLIC_APP_MODE=customer next start -p 3000",
    "start:admin": "cross-env NEXT_PUBLIC_APP_MODE=admin next start -p 3001",
    "build:clean": "npm run clean && cross-env NEXT_PUBLIC_APP_MODE=customer next build"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.383.0",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}
