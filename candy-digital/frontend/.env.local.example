# URL của backend API (cùng cho cả 2 trang)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Giúp 2 trang biết URL của trang còn lại để chuyển qua lại
# (đường dẫn của trang admin và trang khách hàng)
NEXT_PUBLIC_CUSTOMER_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001/admin

# Chế độ mô phỏng thanh toán (ẩn QR/STK shop). Mặc định: tắt. Phải cùng lúc bật DEMO_SIMULATE_PREPAID_PAYMENT=1 ở backend.
NEXT_PUBLIC_DEMO_SIMULATE_PAYMENT=0

# NEXT_PUBLIC_APP_MODE được set tự động bởi npm scripts (dev:customer / dev:admin)
# Bạn KHÔNG cần khai báo biến này trong file .env.local.
